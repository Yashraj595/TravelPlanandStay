<% layout("/layouts/boilerplate") -%>

<style>
  .listing-detail-container {
    max-width: 700px;
    margin: 50px auto;
    padding: 0 15px;
  }

  .listing-detail-container h2 {
    font-size: 1.6rem;
    font-weight: 600;
    color: #222;
    margin-bottom: 20px;
  }

  .listing-detail-container img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 20px;
  }

  .listing-detail-body p {
    margin: 6px 0;
    color: #333;
    line-height: 1.5;
  }

  .listing-detail-body .listing-title-text {
    font-weight: 700;
    font-size: 1.05rem;
    color: #111;
  }

  .listing-actions {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .btn-edit-link,
  .btn-delete {
    border: none;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 10px 24px;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn-edit-link {
    background-color: #fe424d;
    color: #fff;
  }

  .btn-edit-link:hover {
    background-color: #e63946;
    color: #fff;
    opacity: 0.95;
  }

  .btn-delete {
    background-color: #1a1a1a;
    color: #fff;
  }

  .btn-delete:hover {
    background-color: #000;
    color: #fff;
  }
</style>

<body>
  <div class="listing-detail-container">
    <h2>Listing Details</h2>

    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">

    <div class="listing-detail-body">
      <p class="listing-title-text"><%= listing.title %></p>
      <p><%= listing.description %></p>
      <p>&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
      <p><%= listing.location %></p>
      <p><%= listing.country %></p>
    </div>

    <div class="listing-actions">
      <a href="/Listing/<%= listing._id %>/edit" class="btn-edit-link">Edit</a>

      <form method="POST" action="/Listing/<%= listing._id %>?_method=DELETE">
        <button type="submit" class="btn-delete">Delete</button>
      </form>
    </div>
  </div>
</body>